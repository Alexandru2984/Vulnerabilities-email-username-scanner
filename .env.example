# Server Settings
PORT=8088
HOST=0.0.0.0
MAX_CONCURRENT_SCANS=3

# Docker Compose Settings
APP_BIND_PORT=8088
POSTGRES_USER=recon_user
POSTGRES_PASSWORD=change_me_generate_a_strong_database_password
POSTGRES_DB=recon_db

# Database Settings
# For docker compose, use host "postgres".
# For ./run.sh local cargo mode, use host "127.0.0.1" and port 5454.
DATABASE_URL=postgres://recon_user:change_me_generate_a_strong_database_password@postgres:5432/recon_db

# Authentication
# ⚠️  REQUIRED: Generate a strong random key for production!
# Example: openssl rand -hex 32
API_KEY=changeme_generate_a_secure_key

# Logging (optional)
# RUST_LOG=info,antigravity_loose=debug

# Plugin Keys (Optional)
# HIBP_API_KEY=your_key_here
# GITHUB_TOKEN=your_token_here
